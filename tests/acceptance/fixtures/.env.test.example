# Acceptance test credentials
#
# Copy this file to .env.test in the project root and fill in your keys.
# .env.test is gitignored — never commit real credentials.
#
# Only include the keys needed for the providers in fixtures/ax.yaml.

# Required for LLM calls via OpenRouter
OPENROUTER_API_KEY=sk-or-v1-...

# Required for embedding tests (BT-8, BT-9, IT-7, IT-8)
# Leave blank to skip embedding tests gracefully.
OPENAI_API_KEY=sk-...
